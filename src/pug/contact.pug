doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='')
        meta(name='author', content='')

        title Contact - Robert Marston

        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        include includes/css.pug

    body

        include includes/navbar.pug

        // Page Header
        header.masthead(style="background-image: url('assets/img/contact-bg.jpg')")
            .container.position-relative.px-4.px-lg-5
                .row.gx-4.gx-lg-5.justify-content-center
                    .col-md-10.col-lg-8.col-xl-7
                        .page-heading
                            h1 Contact Me
                            span.subheading Have questions? I have answers.

        // Main Content
        main.mb-4
            .container.px-4.px-lg-5
                .row.gx-4.gx-lg-5.justify-content-center
                    .col-md-10.col-lg-8.col-xl-7
                        p
                            | Want to get in touch? Fill out the form below to send me a message and I will get back to you as soon as possible!

                        .my-5

                            form#contactForm
                                .form-floating
                                    input#name.form-control(
                                        name='name',
                                        type='text',
                                        placeholder='Enter your name...',
                                        required
                                    )
                                    label(for='name') Name
                                .form-floating
                                    input#email.form-control(
                                        name='email',
                                        type='email',
                                        placeholder='Enter your email...',
                                        required
                                    )
                                    label(for='email') Email address
                                .form-floating
                                    input#company.form-control(
                                        name='company',
                                        type='text',
                                        placeholder='Enter your company...'
                                    )
                                    label(for='company') Company
                                .form-floating
                                    select#type.form-control(name='type')
                                        option(value='General Inquiry') General Inquiry
                                        option(value='Project Request') Project Request
                                        option(value='Job Opportunity') Job Opportunity
                                        option(value='Other') Other
                                    label(for='type') Inquiry Type
                                .form-floating
                                    textarea#message.form-control(
                                        name='message',
                                        placeholder='Enter your message here...',
                                        style='height: 12rem;',
                                        required
                                    )
                                    label(for='message') Message

                                // Honeypot field
                                input#website(type='text', name='website', style='display:none', tabindex='-1', autocomplete='off')

                                br

                                // Submit success message
                                #submitSuccessMessage.d-none
                                    .text-center.mb-3
                                        .fw-bolder Form submission successful!

                                // Submit error message
                                #submitErrorMessage.d-none
                                    .text-center.text-danger.mb-3 Error sending message!

                                // Submit Button
                                button#submitButton.btn.btn-primary.text-uppercase(type='submit') Send

        include includes/footer.pug

        include includes/scripts.pug

        script.
            const form = document.getElementById('contactForm');
            const submitButton = document.getElementById('submitButton');
            const successMessage = document.getElementById('submitSuccessMessage');
            const errorMessage = document.getElementById('submitErrorMessage');

            form?.addEventListener('submit', async (e) => {
                e.preventDefault();

                // Disable button to prevent double submission
                submitButton.disabled = true;
                errorMessage.classList.add('d-none');

                const formData = new FormData(form);
                const payload = {
                    name: formData.get('name'),
                    email: formData.get('email'),
                    company: formData.get('company'),
                    type: formData.get('type'),
                    message: formData.get('message'),
                    website: formData.get('website')
                };

                try {
                    const res = await fetch('https://api.rmarston.com/contact', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await res.json();

                    if (res.ok && data.ok) {
                        window.location.href = '/thank-you.html';
                        return;
                    }

                    throw new Error(data.error || 'Failed to send');
                } catch (err) {
                    console.error(err);
                    errorMessage.classList.remove('d-none');
                    submitButton.disabled = false;
                }
            });
